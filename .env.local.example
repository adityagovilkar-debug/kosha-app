# Copy this file to `.env.local` and fill in the values.
#
# Kosha deliberately shares its Supabase project with the Nudge app (see
# KOSHA-PLAN.md §2.1) — the account is at the free-tier project limit, and
# Nudge sees very little use. So: use the SAME NEXT_PUBLIC_SUPABASE_URL and
# NEXT_PUBLIC_SUPABASE_ANON_KEY as ../nudge/.env.local. Do not create a new
# Supabase project for this app.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Public site URL. Defaults to the app origin if unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3050

# Server-only secret used to encrypt each user's Anthropic API key at rest
# (see lib/server/crypto.ts). Generate once and never commit the real
# value: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If this value ever changes, previously-saved API keys can no longer be
# decrypted and users must re-enter them in Settings.
KOSHA_ENCRYPTION_KEY=generate-a-random-32-byte-hex-string
